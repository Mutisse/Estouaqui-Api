# Frontend URL para CORS
FRONTEND_URL=http://localhost:9000

VITE_APP_NAME="${APP_NAME}"


# Forçar SSL
MYSQL_ATTR_SSL_CA=storage/certs/ca-cert.pem
DB_OPTIONS="charset=utf8mb4&collation=utf8mb4_unicode_ci&ssl-mode=VERIFY_IDENTITY"

MYSQL_ATTR_SSL_CA=storage/certs/ca-cert.pem
MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false
