APP_NAME="EstouAqui API"
APP_ENV=local
APP_KEY=base64:NAMa8Hxh24SA2cXzMd7OSnkmIEqXmz4m3Mh//7ru7mY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_PT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Configuração do TiDB Cloud
DB_CONNECTION=mysql
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_DATABASE=estouaqui_db
DB_USERNAME=31rupKcHsr74din.root
DB_PASSWORD=zwMrJHbOhT0bUUQ6

# Configurações adicionais para TiDB
DB_OPTIONS="charset=utf8mb4&collation=utf8mb4_unicode_ci"
MYSQL_ATTR_SSL_CA= # Caminho para o certificado CA se necessário

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@estouaqui.com"
